; Engine configuration file.
; It is best edited using the editor and not directly.
;
; Format:
;   [section]
;   param=value

config_version=5

[application]

config/name="Catch Dog"
run/main_scene="res://src/app/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[input]

steer_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":4194319,"unicode":0)]
}
steer_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":4194321,"unicode":0)]
}
accelerate={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":4194320,"unicode":0)]
}
brake={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":4194322,"unicode":0)]
}
throw_net={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":32,"unicode":0)]
}
pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":4194305,"unicode":0)]
}

[physics]

common/physics_ticks_per_second=60

[rendering]

rendering_device/fallback_to_opengl3=true
textures/vram_compression/import_etc2_astc=true
